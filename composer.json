{
    "name": "puzl/pzmonitor",
    "description": "Lock distribuído sobre Cache::lock do Laravel, com API de monitor por chave única",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/cache": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "illuminate/config": "^10.0|^11.0|^12.0",
        "illuminate/container": "^10.0|^11.0|^12.0",
        "illuminate/redis": "^10.0|^11.0|^12.0",
        "phpunit/phpunit": "^10.5",
        "predis/predis": "^2.2",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "Puzl\\PzMonitor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Puzl\\PzMonitor\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Puzl\\PzMonitor\\Laravel\\PzMonitorServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit -c phpunit.xml.dist",
        "test:coverage": "phpunit -c phpunit.xml.dist --coverage-html coverage"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
